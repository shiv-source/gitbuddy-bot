{
  "mcpServers": {
    "graphify": {
      "command": "graphify-mcp",
      "args": [
        "graphify-out/graph.json"
      ],
      "type": "stdio"
    },
    "code-review-graph": {
      "command": "uvx",
      "args": [
        "code-review-graph",
        "serve"
      ],
      "type": "stdio"
    }
  }
}
