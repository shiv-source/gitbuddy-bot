{
  "name": "gitbuddy-bot",
  "private": true,
  "description": "GitBuddy Bot — monorepo with Probot GitHub App and Docusaurus docs",
  "scripts": {
    "build": "pnpm --filter gitbuddy-bot build",
    "dev": "pnpm --filter gitbuddy-bot dev",
    "start": "pnpm --filter gitbuddy-bot start",
    "test": "pnpm --filter gitbuddy-bot test",
    "test:unit": "pnpm --filter gitbuddy-bot test:unit",
    "test:integration": "pnpm --filter gitbuddy-bot test:integration",
    "test:watch": "pnpm --filter gitbuddy-bot test:watch",
    "lint": "pnpm --filter gitbuddy-bot lint",
    "typecheck": "pnpm --filter gitbuddy-bot typecheck",
    "clean": "pnpm --filter gitbuddy-bot clean",
    "docs:dev": "pnpm --filter docs start",
    "docs:build": "pnpm --filter docs build",
    "docs:deploy": "pnpm --filter docs deploy",
    "docs:typecheck": "pnpm --filter docs typecheck",
    "docs:api": "pnpm --filter docs typedoc"
  },
  "engines": {
    "node": ">=24"
  }
}
